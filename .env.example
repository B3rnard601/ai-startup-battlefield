# ─── AI Provider ─────────────────────────────────────────────────
# Set to 'groq' for free fallback, '0g' for 0G Compute (default)
AI_PROVIDER=groq

# ─── 0G Compute Router ───────────────────────────────────────────
# Get API key at: https://pc.testnet.0g.ai
# Deposit free testnet tokens first: https://faucet.0g.ai
OG_ROUTER_URL=https://router-api-testnet.integratenetwork.work/v1
OG_ROUTER_API_KEY=sk-your-0g-key-here

# ─── Groq (free fallback) ─────────────────────────────────────────
# Free API key at: https://console.groq.com
GROQ_API_KEY=gsk_your-groq-key-here

# ─── 0G Storage ──────────────────────────────────────────────────
# Private key of a funded wallet (get free tokens: https://faucet.0g.ai)
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
OG_PRIVATE_KEY=0x_your_private_key_here

# ─── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
